# ──────────────────────────────────────────
# App  [REQUIRED]
# ──────────────────────────────────────────
NODE_ENV=development        # REQUIRED — development | test | production
PORT=3001                   # REQUIRED — must be a valid port number (1–65535)

# ──────────────────────────────────────────
# Database (PostgreSQL)  [REQUIRED — choose one option]
# ──────────────────────────────────────────

# Option A — single connection URL (takes precedence when set)
DATABASE_URL=               # e.g. postgresql://user:pass@host:5432/dbname

# Option B — individual connection parameters (used when DATABASE_URL is empty)
DB_HOST=                    # REQUIRED if DATABASE_URL is not set
DB_PORT=5432                # REQUIRED if DATABASE_URL is not set
DB_USERNAME=                # REQUIRED if DATABASE_URL is not set
DB_PASSWORD=                # REQUIRED if DATABASE_URL is not set
DB_NAME=                    # REQUIRED if DATABASE_URL is not set

# ──────────────────────────────────────────
# JWT Secrets  [REQUIRED]
# ──────────────────────────────────────────
JWT_SECRET=                 # REQUIRED — min 32 chars; use: openssl rand -hex 32
JWT_REFRESH_SECRET=         # REQUIRED — min 32 chars; use: openssl rand -hex 32
JWT_ACCESS_EXPIRES_IN=15m   # REQUIRED — e.g. 15m, 1h
JWT_REFRESH_EXPIRES_IN=7d   # REQUIRED — e.g. 7d, 30d

# ──────────────────────────────────────────
# CORS  [REQUIRED in production]
# ──────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000   # comma-separated list; set to your frontend URL in production

# ──────────────────────────────────────────
# Health check memory thresholds (MB)  [OPTIONAL]
# ──────────────────────────────────────────
MEMORY_HEAP_THRESHOLD_MB=300
MEMORY_RSS_THRESHOLD_MB=300
