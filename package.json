{
  "name": "sitepilot-backend",
  "version": "1.0.0",
  "description": "SaaS platform for website automation, SEO and AI tools",
  "author": "",
  "private": true,
  "engines": {
    "node": ">=20 <25",
    "npm": ">=10 <11"
  },
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "start:container": "node dist/database/run-migrations.js && node dist/main.js",
    "dev": "npm run start:dev",
    "dev:safe": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/free-port-3000.ps1 && npm run start:dev",
    "dev:db": "docker compose up -d postgres",
    "dev:up": "docker compose up -d",
    "dev:down": "docker compose down",
    "docker:build": "docker compose build --no-cache backend",
    "docker:up": "docker compose up -d backend",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v --remove-orphans",
    "docker:logs": "docker compose logs backend postgres",
    "db:migrate:run": "typeorm-ts-node-commonjs migration:run -d src/data-source.ts",
    "db:migrate:revert": "typeorm-ts-node-commonjs migration:revert -d src/data-source.ts",
    "db:migrate:generate": "typeorm-ts-node-commonjs migration:generate src/database/migrations/$npm_config_name -d src/data-source.ts",
    "db:seed": "ts-node -r tsconfig-paths/register src/database/seed.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/swagger": "^11.2.7",
    "@nestjs/throttler": "^6.2.1",
    "@nestjs/typeorm": "^10.0.2",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.1.1",
    "@nestjs/testing": "^10.3.0",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.30",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}