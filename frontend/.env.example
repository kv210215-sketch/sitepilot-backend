# ──────────────────────────────────────────
# App
# ──────────────────────────────────────────
# Server-side only – used by next.config.js rewrites (never bundled to client)
API_URL=https://your-api-domain.up.railway.app/api

# Exposed to the browser (e.g. for direct client-side fetch if needed)
NEXT_PUBLIC_API_URL=https://your-api-domain.up.railway.app/api

# ──────────────────────────────────────────
# Auth (if using NextAuth or similar)
# ──────────────────────────────────────────
NEXTAUTH_SECRET=change-me-to-a-random-256-bit-secret
NEXTAUTH_URL=https://your-frontend-domain.up.railway.app
