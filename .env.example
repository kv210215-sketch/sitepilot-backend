# ─────────────────────────────────────────────────────────────
# SitePilot Backend — Environment Configuration
# Copy to .env and fill in values before running locally.
# NEVER commit your real .env file to git.
# ─────────────────────────────────────────────────────────────

# App
PORT=3000
NODE_ENV=development   # development | production

# ── Database ─────────────────────────────────────────────────
#
# Option A: full URL (Railway auto-injects DATABASE_URL)
# When set, all DB_* params below are ignored.
#
# DATABASE_URL=postgresql://user:password@host:5432/sitepilot
#
# Option B: individual params (local / docker-compose defaults)
#
DB_HOST=localhost
DB_PORT=5432
DB_USER=sitepilot
DB_PASSWORD=sitepilot
DB_NAME=sitepilot
#
# ⚠️  LOCAL POSTGRESQL REQUIREMENT:
# Before running migrations, enable uuid-ossp once per database:
#   psql -U postgres -d sitepilot -c 'CREATE EXTENSION IF NOT EXISTS "uuid-ossp";'
# Or run: .\SAFE_DATABASE_INIT.ps1

# ── Auth (JWT) ────────────────────────────────────────────────
# REQUIRED — app refuses to start if missing or < 32 chars.
# Generate: openssl rand -hex 32
# PowerShell: -join ((1..32)|%{'{0:x2}' -f (Get-Random -Max 256)})
JWT_SECRET=change-this-to-a-secure-random-secret-min-32-chars

# REQUIRED in production — must be DIFFERENT from JWT_SECRET.
# In development, falls back to JWT_SECRET+'-refresh-dev-only' if not set.
# Generate: openssl rand -hex 32
JWT_REFRESH_SECRET=change-this-to-another-secure-random-secret-32-chars

# Access token lifetime (default 15m in production, 15m dev)
JWT_EXPIRES_IN=15m

# Refresh token lifetime (default 7d)
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────────
# REQUIRED in production (CORS_ORIGIN=* is blocked by ENV validation).
# Set to your frontend Railway/public URL.
# Multiple origins: comma-separated.
CORS_ORIGIN=*

# ── Rate Limiting ──────────────────────────────────────────────
# Global defaults. Individual sensitive endpoints (login, register)
# are hard-coded to 10 req/min regardless of these values.
THROTTLE_TTL=60000     # window in milliseconds (default: 60 000 = 1 minute)
THROTTLE_LIMIT=100     # max requests per window per IP (default: 100)

# ── Stripe (future) ──────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
