# ─────────────────────────────────────────────────────────────
# SitePilot Backend — Environment Configuration
# Copy to .env and fill in values before running locally.
#
# NEVER commit your real .env file — only this .env.example.
# ─────────────────────────────────────────────────────────────

# App
PORT=3000
NODE_ENV=development   # development | production

# ── Database ─────────────────────────────────────────────────
#
# Option A: full URL (Railway auto-injects DATABASE_URL for you)
# Use this in production. When DATABASE_URL is set, all DB_* vars below are ignored.
#
# DATABASE_URL=postgresql://user:password@host:5432/sitepilot
#
# Option B: individual params (used when DATABASE_URL is absent)
# These defaults match the docker-compose.yml postgres service and local dev setup.
#
DB_HOST=localhost
DB_PORT=5432
DB_USER=sitepilot
DB_PASSWORD=sitepilot
DB_NAME=sitepilot
#
# ⚠️  LOCAL POSTGRESQL REQUIREMENT:
# Before running migrations, enable the uuid-ossp extension once per database:
#   psql -U postgres -d sitepilot -c 'CREATE EXTENSION IF NOT EXISTS "uuid-ossp";'
# Or run: .\SAFE_DATABASE_INIT.ps1

# ── Auth ─────────────────────────────────────────────────────
# REQUIRED — app throws on startup if missing.
# Generate with: openssl rand -hex 32
#   or in PowerShell: -join ((1..32) | ForEach-Object { '{0:x2}' -f (Get-Random -Max 256) })
JWT_SECRET=change-this-to-a-secure-random-secret-min-32-chars
# REQUIRED in production, optional in development (defaults to 7d)
JWT_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────────
# REQUIRED in production — app throws if NODE_ENV=production and CORS_ORIGIN is not set.
# Set to your frontend Railway/public URL in production.
# Multiple origins: comma-separated
#   CORS_ORIGIN=https://foo.up.railway.app,https://app.sitepilot.io
# Use * only for local development.
CORS_ORIGIN=*

# ── Stripe (future) ──────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
