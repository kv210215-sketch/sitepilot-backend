# App
PORT=3000
NODE_ENV=development

# Database (use DATABASE_URL for Railway/cloud, or individual params for local)
# Option A: Connection URL (Railway auto-injects this)
DATABASE_URL=postgresql://postgres:password@localhost:5432/sitepilot

# Option B: Individual params (for local development without DATABASE_URL)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=sitepilot

# JWT
JWT_SECRET=change-this-to-a-secure-random-secret-min-32-chars
JWT_EXPIRES_IN=7d

# CORS (comma-separated allowed origins, or * for all)
CORS_ORIGIN=*

# Stripe (future - leave empty for now)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
