# ──────────────────────────────────────────
# Root .env.example
# Copy to .env and fill in values before
# running docker-compose locally.
# ──────────────────────────────────────────

# ── Backend ────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost:3000
MEMORY_HEAP_THRESHOLD_MB=300
MEMORY_RSS_THRESHOLD_MB=300

# ── Frontend ───────────────────────────────
# Server-side URL used by Next.js rewrites (not exposed to browser)
API_URL=http://backend:4000/api
# Browser-visible URL (only needed for direct client-side calls)
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXTAUTH_SECRET=change-me-to-a-random-256-bit-secret
NEXTAUTH_URL=http://localhost:3000
