# ─────────────────────────────────────────────────────────────
# SitePilot Backend — Environment Configuration
# Copy to .env and fill in values before running locally.
# ─────────────────────────────────────────────────────────────

# App
PORT=3000
NODE_ENV=development   # development | production

# ── Database ─────────────────────────────────────────────────
# Option A: full URL (Railway auto-injects DATABASE_URL for you)
# DATABASE_URL=postgresql://user:password@host:5432/sitepilot

# Option B: individual params (used when DATABASE_URL is absent)
# These defaults match the docker-compose.yml postgres service.
DB_HOST=localhost
DB_PORT=5432
DB_USER=sitepilot
DB_PASSWORD=sitepilot
DB_NAME=sitepilot

# ── Auth ─────────────────────────────────────────────────────
# IMPORTANT: change JWT_SECRET before deploying to production!
# Generate one: openssl rand -hex 32
JWT_SECRET=change-this-to-a-secure-random-secret-min-32-chars
JWT_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────────
# Set to your frontend URL in production, e.g. https://app.sitepilot.io
CORS_ORIGIN=*

# ── Stripe (future) ──────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
