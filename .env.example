NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3001

# Use either DATABASE_URL or DB_* fields
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=sitepilot
DB_SSL=false
DB_SYNCHRONIZE=true

JWT_SECRET=replace-with-at-least-32-characters
JWT_EXPIRES_IN=1d
