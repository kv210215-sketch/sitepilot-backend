# Application
NODE_ENV=development
PORT=3000
APP_NAME=sitepilot-backend

# CORS (comma-separated allowed origins; leave empty to allow all)
# CORS_ORIGINS=https://app.example.com,https://www.example.com

# Database (add when needed)
# DATABASE_URL=postgresql://user:password@localhost:5432/sitepilot

# JWT (add when auth is configured)
# JWT_SECRET=change-me-in-production
# JWT_EXPIRES_IN=3600s

# OpenAI / AI Tools (add when AI features are configured)
# OPENAI_API_KEY=sk-...

# Redis (add when caching / queues are configured)
# REDIS_URL=redis://localhost:6379
